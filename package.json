{
  "name": "clawtask",
  "version": "0.1.0",
  "private": true,
  "description": "Lightweight local task inbox for peer agents on the same host",
  "bin": {
    "clawtask": "./dist/cli.js"
  },
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "dev": "tsx src/cli.ts",
    "test": "tsx --test test/**/*.test.ts",
    "verify": "npm run build && npm run test"
  },
  "engines": {
    "node": ">=20"
  },
  "dependencies": {
    "better-sqlite3": "^11.10.0"
  },
  "devDependencies": {
    "@types/better-sqlite3": "^7.6.12",
    "@types/node": "^24.0.10",
    "tsx": "^4.19.4",
    "typescript": "^5.8.3"
  }
}
